{
  "name": "tacticalshack",
  "version": "0.0.1",
  "description": "Precision shooter's utility platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "start": "npm run start --prefix server",
    "build": "npm run build --prefix client",
    "db:generate": "npm run db:generate --prefix server",
    "db:migrate": "npm run db:migrate --prefix server",
    "db:migrate:deploy": "npm run db:migrate:deploy --prefix server",
    "db:seed": "npm run db:seed --prefix server",
    "postinstall": "npm install --prefix client && npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
