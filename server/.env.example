# Database (required for Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/tacticalshack"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Clerk (for auth - optional for development)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Google (optional - for Places API and Maps)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# Cloudinary (optional - for photos and FFL PDF uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (optional - for claim notification emails)
RESEND_API_KEY=
EMAIL_FROM=noreply@tacticalshack.com
ADMIN_EMAIL=admin@tacticalshack.com
